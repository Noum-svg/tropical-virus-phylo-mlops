models/**
!models/
!models/.gitkeep
*.log

# MLflow / DVC
mlruns/
.dvc/cache/
.dvc/tmp/

# Generated reports (keep hand-written docs + .gitkeep)
reports/evaluation_report.md
reports/scraper_stats.md

# Reference material (not source)
*.pdf

# Leftover duplicate spec folder (kept locally, not tracked)
Nouveau dossier/

